modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[userenv]

[userenv.shared]
VITE_API_URL = ""
PORT = "5000"
EVOLUTION_API_URL = "https://evogo.pre-atendimento.com"

[userenv.development]
VITE_API_URL = "/api"

[nix]
packages = []
channel = "stable-25_05"

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000
